APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
WORKDIR=./workdir

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/subtitle_bot

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_BOT_USERNAME=
X_BOT_USER_ID=
X_API_BASE_URL=https://api.x.com

ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TIMEOUT_SECONDS=120

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5

ELEVENLABS_MAX_DURATION_SECONDS=300
ELEVENLABS_MAX_FILESIZE_MB=25
HARD_MAX_VIDEO_DURATION_SECONDS=3600
HARD_MAX_FILESIZE_MB=512

MENTION_POLL_INTERVAL_SECONDS=60
MENTION_LOOKBACK_LIMIT=20

MAX_CHARS_PER_LINE=42
MAX_LINES_PER_BLOCK=2
MIN_BLOCK_DURATION=1.2
MAX_BLOCK_DURATION=6.0

ADMIN_TOKEN=local-admin-token
PUBLIC_BASE_URL=http://localhost:8000
TEMP_DIR_NAME=tasks

# Notes:
# 1. For mention polling, X_BOT_USER_ID is optional.
# 2. If X_BOT_USER_ID is empty, the app will resolve it automatically from X_BOT_USERNAME.
