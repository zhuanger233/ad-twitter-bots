FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg fontconfig fonts-noto-cjk fonts-noto-color-emoji && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .

CMD ["celery", "-A", "app.workers.celery_app.celery_app", "worker", "-Q", "queue_mentions,queue_io,queue_asr,queue_ffmpeg,queue_post", "--loglevel=INFO"]
